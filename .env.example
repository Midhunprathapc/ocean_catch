# Neon PostgreSQL — get from https://neon.tech
# DATABASE_URL  → use the pooler connection string (for runtime queries)
# DIRECT_URL    → use the direct (non-pooler) string (for migrations/db push)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Cloudinary — get from https://cloudinary.com/console
# NEXT_PUBLIC_ vars are exposed to the browser (needed for unsigned upload)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your_unsigned_preset"

# Cloudinary API credentials (server-side only — never expose to browser)
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Admin panel secret — use a long random string in production
# Generate one: openssl rand -hex 32
ADMIN_SECRET="change_this_to_a_strong_secret"
