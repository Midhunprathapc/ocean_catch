{
  "info": {
    "name": "Fish Store API",
    "description": "API tests for the Fish Store application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "    pm.response.to.have.header('Content-Type');",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response has paginated structure', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('products');",
                  "    pm.expect(jsonData).to.have.property('total');",
                  "    pm.expect(jsonData).to.have.property('page');",
                  "    pm.expect(jsonData).to.have.property('limit');",
                  "    pm.expect(jsonData).to.have.property('pages');",
                  "    pm.expect(jsonData.products).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Save first product ID for next request', function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.products.length > 0) {",
                  "        pm.collectionVariables.set('product_id', jsonData.products[0].id);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{API_URL}}/api/products",
              "host": ["{{API_URL}}"],
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Product has required fields', function () {",
                  "    const product = pm.response.json();",
                  "    pm.expect(product).to.have.property('id');",
                  "    pm.expect(product).to.have.property('title');",
                  "    pm.expect(product).to.have.property('price');",
                  "    pm.expect(product).to.have.property('category');",
                  "});",
                  "",
                  "pm.test('Price is a positive number', function () {",
                  "    const product = pm.response.json();",
                  "    pm.expect(product.price).to.be.a('number');",
                  "    pm.expect(product.price).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{API_URL}}/api/products/{{product_id}}",
              "host": ["{{API_URL}}"],
              "path": ["api", "products", "{{product_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Get All Orders (Unauthenticated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Returns 401 Unauthorized without auth', function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{API_URL}}/api/orders",
              "host": ["{{API_URL}}"],
              "path": ["api", "orders"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "product_id",
      "value": ""
    }
  ]
}
